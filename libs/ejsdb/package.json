{
  "name": "@epanet-js/ejsdb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./worker-api": "./src/worker-api.ts"
  },
  "typesVersions": {
    "*": {
      "worker-api": ["./src/worker-api.ts"]
    }
  },
  "scripts": {
    "lint": "eslint --cache --ext .ts src",
    "lint:fix": "eslint --cache --ext .ts src --fix",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "3.51.2-build9",
    "comlink": "^4.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unused-imports": "^3.2.0",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.5"
  }
}
